@startuml c4-container
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_WITH_LEGEND()

title MFA Template — C4 Container

Person(user, "End User")
System_Ext(ag, "API Gateway")
System_Ext(idp, "Identity Provider (IdP)")
System_Ext(secservice, "SecService")
System_Ext(ms, "Microservice")
System_Ext(kafka, "Kafka")

System_Boundary(mfaSystem, "MFA Service") {
    Container(mfaApp, "MFA Spring Boot App", "Java 21, Spring Boot 4", "Handles session management, inner-token swap, request proxying, and reference-data caching.")
    ContainerDb(h2, "H2 In-Memory DB", "H2", "Stores active sessions and the reference-data cache. Replace with Redis/DataGrid in production.")
}

Rel(ag, mfaApp, "REST (mTLS)", "HTTPS")
Rel(mfaApp, ms, "REST (mTLS + inner-token)", "HTTPS")
Rel(mfaApp, idp, "OAuth2 OIDC", "HTTPS")
Rel(mfaApp, secservice, "Token swap", "HTTPS mTLS")
Rel(mfaApp, kafka, "Consumes reference-data events", "Kafka")
Rel(mfaApp, h2, "JPA", "JDBC")
Rel(user, ag, "HTTPS", "via MFE")
@enduml
