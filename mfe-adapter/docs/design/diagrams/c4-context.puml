@startuml c4-context
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

LAYOUT_WITH_LEGEND()

title MFA Template — C4 Context

Person(user, "End User", "Uses the web application via a browser.")
System(mfe, "Angular MFE", "Single-page application running in the browser.")
System_Boundary(platform, "Platform") {
    System(ag, "API Gateway", "Edge proxy: rate limiting, TLS termination, API-key validation.")
    System(mfa, "MFA", "Micro-Frontend Adapter: session management, token swap, MS routing.")
    System(ms, "Microservice", "Domain business logic exposed via REST API.")
    System(ias, "IAS\n(Identity & Access Service)", "Issues inner tokens with RBAC/ABAC claims.")
}
System_Ext(keycloak, "KeyCloak", "Identity Provider — OIDC / OAuth2 Authorization Server.")
System_Ext(refDataMs, "Reference Data MS", "Publishes reference-data changes via Kafka.")
System_Ext(kafka, "Kafka", "Event streaming platform for reference-data events.")

Rel(user, mfe, "Uses", "HTTPS")
Rel(mfe, ag, "HTTP calls", "HTTPS / REST")
Rel(ag, mfa, "Forwards requests", "HTTPS mTLS + X-API-Key-Validated")
Rel(mfa, ms, "Proxies requests", "HTTPS mTLS + inner-token Bearer")
Rel(mfa, ias, "Token swap", "HTTPS mTLS")
Rel(mfa, keycloak, "OAuth2 code exchange / revoke", "HTTPS")
Rel(refDataMs, kafka, "Publishes events", "Kafka produce")
Rel(mfa, kafka, "Consumes events", "Kafka consume")
Rel(mfe, keycloak, "Login redirect", "HTTPS")
@enduml
