# Pre-built image for Family Ties application
# Requires: app/build/libs/familyTies-*.jar must exist on the host before building.
# Build locally first: ./gradlew :app:bootJar -x test --no-daemon
# Then run: docker compose -f docker-compose.prebuilt.yml up --build
FROM eclipse-temurin:21-jre AS runtime
WORKDIR /app

# Install curl for health checks
RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

# Create a non-root user
RUN groupadd -r familyties && useradd -r -g familyties familyties

# Copy the pre-built jar from the host build output
COPY app/build/libs/familyTies-*.jar app.jar

# Change ownership
RUN chown -R familyties:familyties /app

# Switch to non-root user
USER familyties

# Expose ports (HTTP and HTTPS)
EXPOSE 8080 8443

# Health check (HTTPS with self-signed cert, use --insecure)
HEALTHCHECK --interval=30s --timeout=3s --start-period=60s --retries=3 \
  CMD curl -sfk https://localhost:8443/actuator/health || exit 1

ENTRYPOINT ["java", "-jar", "/app/app.jar"]
