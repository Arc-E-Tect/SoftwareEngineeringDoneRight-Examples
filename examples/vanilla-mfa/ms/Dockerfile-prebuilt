# Pre-built image for Vanilla MS application
# Requires: app/build/libs/familyTies-*.jar must exist on the host before building.
# Build locally first: ./gradlew :app:bootJar -x test --no-daemon
# Then run: docker compose -f docker-compose.prebuilt.yml up --build
FROM eclipse-temurin:21-jre AS runtime
WORKDIR /app

# Install curl for health checks
RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

# Create a non-root user
RUN groupadd -r vanilla-ms && useradd -r -g vanilla-ms vanilla-ms

# Copy the pre-built jar from the host build output
COPY app/build/libs/familyTies-*.jar app.jar

# Change ownership
RUN chown -R vanilla-ms:vanilla-ms /app

# Switch to non-root user
USER vanilla-ms

# Expose port
EXPOSE 8081

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=40s --retries=3 \
  CMD curl -f http://localhost:8081/actuator/health || exit 1

# Run the application
ENTRYPOINT ["java", "-jar", "/app/app.jar"]
