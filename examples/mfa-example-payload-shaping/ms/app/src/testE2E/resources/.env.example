# Environment variables for E2E testing - REQUIRED
# Run ./setup-test-env.sh to generate this file with non-secret values
#
# The .env file is in .gitignore and will not be committed to git.

# Required shell variables (NOT persisted in .env files):
# export POSTGRES_PASSWORD=<your-strong-postgres-password>
# export H2_PASSWORD=<your-strong-h2-password>

# H2 Database Configuration (for unit and component tests)
# Non-secret values only. Password is environment-only.
H2_USERNAME=sa

# PostgreSQL Configuration (for E2E tests with Docker Compose)
# Non-secret values only. Password is environment-only.
POSTGRES_DB=familyties
POSTGRES_USER=familyties
