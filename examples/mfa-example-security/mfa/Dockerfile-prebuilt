# Pre-built image for Security-MFA application
# Requires: build/libs/security-mfa-*.jar must exist on the host before building.
# Build locally first: ./gradlew bootJar -x test --no-daemon  (run inside mfa/)
# Then run: docker compose -f docker-compose.prebuilt.yml up --build  (from example root)
FROM eclipse-temurin:21-jre AS runtime
WORKDIR /app

# Install curl for health checks
RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

# Create a non-root user
RUN groupadd -r security-mfa && useradd -r -g security-mfa security-mfa

# Copy the pre-built jar from the host build output
COPY build/libs/security-mfa-*.jar app.jar

# Change ownership
RUN chown -R security-mfa:security-mfa /app

# Switch to non-root user
USER security-mfa

# Expose port
EXPOSE 8080

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=40s --retries=3 \
  CMD curl -f http://localhost:8080/actuator/health || exit 1

# Run the application with the security-mfa profile
ENTRYPOINT ["java", "-Dspring.profiles.active=security-mfa", "-jar", "/app/app.jar"]
